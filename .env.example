# Copy to `.env` for local development. Optionally use `.env.local` for secrets
# that override `.env` (same behavior as Next.js). Never commit either file.

# --- Database (Supabase Postgres) — use BOTH URLs in production-style setups ---
#
# This repo does not use Prisma; there is no DIRECT_URL. Use POSTGRES_URL_MIGRATE for CLI.
#
# 1) RUNTIME — required on Vercel and recommended for `pnpm dev`:
#    Supabase → Project Settings → Database → Connection pooling → **Transaction** mode.
#    Host: `*.pooler.supabase.com`, port **6543** (Supavisor pooler).
POSTGRES_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Optional alias (some hosts set this instead of POSTGRES_URL):
# DATABASE_URL=

# 2) DRIZZLE CLI — `pnpm db:migrate`, `pnpm db:push`, `pnpm db:pull`:
#    Prefer **Session pooler** (IPv4-friendly, port **5432**, same host family as transaction pooler):
#    Supabase → Database → Connection pooling → **Session** mode URI.
#    Direct `db.<PROJECT_REF>.supabase.co:5432` is often **IPv6-only**; on Windows you may see
#    getaddrinfo ENOTFOUND — use Session pooler for local migrations instead.
#    Do not use Transaction pooler (6543) for CLI; DDL is unreliable there.
POSTGRES_URL_MIGRATE=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Example direct URI (only if your network can reach IPv6 or you use Supabase IPv4 add-on):
# POSTGRES_URL_MIGRATE=postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Optional tuning for `postgres.js`
# POSTGRES_MAX_CONNECTIONS=10
# POSTGRES_CONNECT_TIMEOUT=15

# Dev-only: silence `[flow-guide]` DB hints from `instrumentation.ts`
# SKIP_DB_ENV_WARNINGS=1

# --- Auth (app sessions — NOT Supabase Auth) ---
# Flow Guide signs HTTP-only JWT cookies (`lib/auth/session.ts`) and stores users in Postgres
# (`users.password_hash`, bcrypt). Supabase Auth / GoTrue is not used for sign-in.
# Generate: openssl rand -base64 32
# Required when VERCEL=1 or NODE_ENV=production.
AUTH_SECRET=

# Local http://localhost: use non-secure session cookies by default. Force secure cookies:
# COOKIE_SECURE=1
# Or disable in production-like local tests:
# COOKIE_SECURE=0

# --- App URL ---
BASE_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***

# --- Supabase Storage (admin course cover + media — `/api/admin/media/upload`) ---
# Server-only: uses the service role key (never prefix with NEXT_PUBLIC_).
#
# Project URL — set at least one (same value: https://<ref>.supabase.co):
#   • SUPABASE_URL — preferred name on the server
#   • OR NEXT_PUBLIC_SUPABASE_URL — if you already use this for a Supabase browser client,
#     the upload API will fall back to it so uploads work without duplicating the URL.
SUPABASE_URL=https://[PROJECT_REF].supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
#
# Required for uploads — Supabase → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=
#
# Bucket id — create in Supabase → Storage (public bucket recommended for course cards / lesson URLs).
# Default if unset: course-media. Alias env name also supported:
# SUPABASE_STORAGE_BUCKET=media
SUPABASE_MEDIA_BUCKET=course-media

# Bootstrap missing keys from existing .env: pnpm ensure:storage-env
# After filling secrets, verify Storage: pnpm check:storage
# Bucket SQL: scripts/supabase-storage-course-media.sql
