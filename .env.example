# Copy to `.env` for local development. Never commit `.env`.
# The SaaS starter loads `.env` by default (see dotenv in lib/db/drizzle.ts).

# --- Database (Supabase Postgres) — use BOTH URLs below ---
#
# 1) RUNTIME (required on Vercel + recommended for `pnpm dev`):
#    Supabase → Database → Connection pooling → **Transaction** mode (Shared Pooler).
#    Host usually looks like `aws-0-<REGION>.pooler.supabase.com`, port **6543**.
POSTGRES_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# 2) MIGRATIONS (`pnpm db:migrate`, `pnpm db:seed` from your machine):
#    Supabase → Database → **Direct connection** (`db.<PROJECT_REF>.supabase.co`, port **5432**).
#    Set this even when POSTGRES_URL uses the pooler — drizzle.config.ts reads POSTGRES_URL_MIGRATE first.
#    If direct host is IPv4-incompatible on your network, use Session pooler or Supabase IPv4 add-on (see README).
POSTGRES_URL_MIGRATE=postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Optional tuning for `postgres.js` (defaults are fine for most Supabase + Vercel setups)
# POSTGRES_MAX_CONNECTIONS=10
# POSTGRES_CONNECT_TIMEOUT=15

# --- Auth ---
# Generate: openssl rand -base64 32 (or Node: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))").
# Required when VERCEL=1 or NODE_ENV=production. In next dev, unset or blank falls back to a dev-only secret (set a real value locally anyway).
AUTH_SECRET=

# --- App URL ---
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app or your custom domain (must match Stripe redirect URLs)
BASE_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
